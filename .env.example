# ─────────────────────────────────────────────────────────────
# Mandarin — environment variables
# Copy to .env.local and fill in. Every integration is optional:
# the app runs without keys, and each feature turns on once its
# keys are present.
# ─────────────────────────────────────────────────────────────

# Public base URL (used for OAuth + Stripe redirects). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Market data ──────────────────────────────────────────────
# The Odds API (https://the-odds-api.com) — powers live sportsbook
# arbitrage. Free tier ~500 requests/month; the server caches responses.
ODDS_API_KEY=
# Optional overrides:
# ODDS_API_REGIONS=us
# ODDS_API_SPORTS=americanfootball_nfl,basketball_nba,icehockey_nhl,americanfootball_ncaaf,mma_mixed_martial_arts,soccer_epl
# MARKET_CACHE_TTL_MS=60000
#
# Trust controls (for acting on real money):
# ONLY show arbs between books you can actually bet at — set this to YOUR books.
# ODDS_API_BOOKS=draftkings,fanduel,betmgm,caesars,betrivers,espnbet
# Drop book quotes older than this many ms (stale price = phantom arb).
# ODDS_API_MAX_QUOTE_AGE_MS=480000
# Edges above this % are flagged "Verify" (almost always a stale line).
# ODDS_API_MAX_EDGE=4.5
#
# Edge Engine V2 (+EV) rollout flags. Fail safe to current behavior if unset.
# EDGE_V2_ENABLED=true            # false → no +EV in the feed (arb + watch only)
# EDGE_V2_SHADOW_MODE=false       # true → compute V2 but don't publish it (dark launch)
# EDGE_V2_DEFAULT_PROFILE=balanced  # conservative | balanced | aggressive
# EDGE_V2_REQUIRE_TIMESTAMPS=true  # drop quotes without a book last_update

# ── Auth (Supabase) ──────────────────────────────────────────
# Create a project at https://supabase.com, then run supabase/schema.sql
# in the SQL editor. Keys live in Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, NEVER expose to the browser. Used by the
# Stripe webhook to write subscription state.
SUPABASE_SERVICE_ROLE_KEY=

# ── Payments (Stripe) ────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# From `stripe listen` locally, or the Dashboard webhook endpoint in prod.
STRIPE_WEBHOOK_SECRET=
# Price IDs for each plan (Products → Pricing → API ID, starts with price_).
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
